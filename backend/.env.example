PORT=5000
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=pharma_inventory
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=24h

# ── WhatsApp notifications (optional) ──────────────────────────
# Without these three set, sale/alert notifications are simply
# logged to the console instead of sent — the app still works
# fully without them. To enable real sending:
#   1. Create an app at developers.facebook.com -> add "WhatsApp"
#   2. Copy the temporary/permanent access token -> WHATSAPP_TOKEN
#   3. Copy the test sender's Phone Number ID -> WHATSAPP_PHONE_NUMBER_ID
#   4. Add the recipient number in E.164 (no +, no spaces) below
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
OWNER_WHATSAPP_NUMBER=919100491753
